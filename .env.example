# ════════════════════════════════════════════════════════════════
# AGN Estética — Template de variáveis de ambiente
# ────────────────────────────────────────────────────────────────
# Copie este arquivo para .env.local e preencha com valores reais.
# .env.local é ignorado pelo git (segredos ficam só na sua máquina).
# Para deploy na Vercel: configurar as mesmas vars no painel do projeto.
# ════════════════════════════════════════════════════════════════


# ─── Next.js ─────────────────────────────────────────────────────
# Desliga o tracking anônimo de uso do Next.js (build/dev).
NEXT_TELEMETRY_DISABLED=1


# ─── Supabase (Etapa 0.4) ────────────────────────────────────────
# URL do projeto Supabase. Padrão: https://<projeto>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Chave pública (anon). Pode ser exposta ao browser — RLS protege os dados.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Chave de serviço (service_role). NUNCA expor ao browser.
# Bypassa RLS. Usar SÓ em código server-side (backend/services).
SUPABASE_SERVICE_ROLE_KEY=


# ─── Sentry (Etapa 0.7) ──────────────────────────────────────────
# DSN do projeto Sentry. Mesmo valor em SENTRY_DSN e NEXT_PUBLIC_SENTRY_DSN.
# (NEXT_PUBLIC_ é usado pelo client; SENTRY_DSN pelo server.)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Token usado SÓ no build (upload de source maps). Não usar em runtime.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=


# ─── Google Analytics 4 (Etapa 0.7) ──────────────────────────────
# ID de medição do GA4. Formato: G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=


# ─── Resend (Etapa 0.7) ──────────────────────────────────────────
# Chave da API do Resend para envio de e-mails operacionais.
# Server-side only.
RESEND_API_KEY=